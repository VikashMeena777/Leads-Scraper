        {
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "// Get AI message\nlet message = '';\ntry {\n  message = $json.choices[0].message.content.trim();\n} catch(e) {\n  const lead = $('Filter Uncontacted').item.json;\n  message = `Hi! I noticed ${lead.business_name} in ${lead.city} and loved your ${lead.category || 'business'}. I help local businesses get more customers through social media and Google. Would you be open to a quick chat? \\n- Vikash`;\n}\n\nconst lead = $('Filter Uncontacted').item.json;\nconst phone = lead.clean_phone;\n\n// Build wa.me link\nconst waLink = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;\n\n// Build Telegram card\nlet tg = `\\ud83c\\udfe2 <b>${lead.business_name}</b>\\n`;\ntg += `\\ud83c\\udff7 ${lead.category || 'Business'} \\u2022 \\ud83c\\udfd9 ${lead.city}`;\nif (lead.rating) tg += ` \\u2022 \\u2b50 ${lead.rating}`;\ntg += `\\n\\ud83d\\udcde ${lead.phone}`;\nif (lead.website && lead.website !== 'None') tg += `\\n\\ud83c\\udf10 ${lead.website}`;\ntg += `\\n\\n\\ud83d\\udcac <i>${message.replace(/</g, '&lt;').replace(/>/g, '&gt;').substring(0, 250)}</i>`;\ntg += `\\n\\n\\ud83d\\udc49 <a href=\\\"${waLink}\\\">TAP TO SEND ON WHATSAPP</a>`;\nif (lead.google_maps_url) tg += `\\n\\ud83d\\udccd <a href=\\\"${lead.google_maps_url}\\\">View on Maps</a>`;\n\nreturn {\n  json: {\n    ...lead,\n    ai_message: message,\n    wa_link: waLink,\n    telegram_text: tg\n  }\n};"
            },
